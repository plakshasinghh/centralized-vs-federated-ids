
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import yaml

from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from sklearn.metrics import (
    confusion_matrix, roc_auc_score, roc_curve,
    accuracy_score, f1_score, precision_score, recall_score
)
from sklearn.ensemble import RandomForestClassifier
from sklearn.tree import DecisionTreeClassifier
from sklearn.linear_model import LogisticRegression
from xgboost import XGBClassifier

from src.data import find_label_column, load_and_preprocess
from src.reporting import ExperimentResult, ResultWriter


NOTEBOOK_FEATURES = [
    "Destination Port",
    "Total Fwd Packets",
    "Total Backward Packets",
    "Total Length of Fwd Packets",
    "Total Length of Bwd Packets",
    "Flow Duration",
    "Init_Win_bytes_forward",
    "act_data_pkt_fwd",
]

MODEL_SLUGS = {
    "XGBoost":             "xgboost",
    "Random Forest":       "random_forest",
    "Decision Tree":       "decision_tree",
    "Logistic Regression": "logistic_regression",
}


def load_config(config_path):
    if config_path and Path(config_path).exists():
        with open(config_path) as f:
            return yaml.safe_load(f)
    return {}


def load_fixed_features(dataset_path, target_col, features, test_size, random_state):
    """Load the CSV and select the fixed notebook feature subset."""
    print(f"\n📂 Loading: {dataset_path}")
    df = pd.read_csv(dataset_path)
    df.columns = df.columns.str.strip()

    label_col = target_col if target_col in df.columns else find_label_column(df.columns)
    if not label_col:
        raise ValueError("❌ No label column found. Run run_combiner first!")

    df["binary_label"] = (df[label_col].str.strip().str.upper() != "BENIGN").astype(int)

    missing = [c for c in features if c not in df.columns]
    if missing:
        raise ValueError(f"❌ Missing expected feature columns: {missing}")

    X = df[features]
    y = df["binary_label"]

    print("Class distribution:")
    print(y.value_counts())
    print("0 = BENIGN, 1 = ATTACK")

    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    X_train, X_test, y_train, y_test = train_test_split(
        X_scaled, y, test_size=test_size, random_state=random_state, stratify=y
    )
    print(f"Train size: {len(X_train)}, Test size: {len(X_test)}")
    return X_train, X_test, y_train.values, y_test.values, features


def _split_all_features(dataset_path, test_size, random_state):
    """Alternate path: use every numeric column, matching the FL script."""
    X, y, scaler, feature_names = load_and_preprocess(dataset_path)
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=test_size, random_state=random_state, stratify=y
    )
    return X_train, X_test, y_train, y_test, feature_names


def run_centralized_models(
    dataset_path,
    target_col="Label",
    test_size=0.2,
    random_state=42,
    reports_dir="reports",
    use_all_features=False,
):
    reports_dir = Path(reports_dir)
    figures_root = reports_dir / "figures"
    results_root = reports_dir / "results"

    sns.set_theme(style="whitegrid")

    if use_all_features:
        X_train, X_test, y_train, y_test, feature_names = _split_all_features(
            dataset_path, test_size, random_state
        )
    else:
        X_train, X_test, y_train, y_test, feature_names = load_fixed_features(
            dataset_path, target_col, NOTEBOOK_FEATURES, test_size, random_state
        )

    models = {
        "XGBoost": XGBClassifier(
            n_estimators=100, max_depth=6, learning_rate=0.1,
            eval_metric="logloss", random_state=random_state,
        ),
        "Random Forest": RandomForestClassifier(
            n_estimators=100, max_depth=10, random_state=random_state, n_jobs=-1,
        ),
        "Decision Tree": DecisionTreeClassifier(max_depth=10, random_state=random_state),
        "Logistic Regression": LogisticRegression(max_iter=1000, random_state=random_state),
    }

    class_names = ["BENIGN", "ATTACK"]
    all_predictions = {}
    all_results = {}

    for name, model in models.items():
        slug = MODEL_SLUGS[name]
        print(f"\nTraining {name}...")
        model.fit(X_train, y_train)
        y_pred = model.predict(X_test)
        y_prob = model.predict_proba(X_test)[:, 1]

        tn, fp, fn, tp = confusion_matrix(y_test, y_pred).ravel()
        metrics = {
            "accuracy":  accuracy_score(y_test, y_pred),
            "f1":        f1_score(y_test, y_pred),
            "precision": precision_score(y_test, y_pred),
            "recall":    recall_score(y_test, y_pred),
            "auc":       roc_auc_score(y_test, y_prob),
        }
        print(f"  Accuracy: {metrics['accuracy']:.4f}  F1: {metrics['f1']:.4f}")

        all_predictions[name] = {"y_pred": y_pred, "y_prob": y_prob}
        all_results[name] = metrics

        # ── Per-model figures ────────────────────────────────────────
        fig_dir = figures_root / slug
        fig_dir.mkdir(parents=True, exist_ok=True)

        fig, ax = plt.subplots(figsize=(6, 5))
        sns.heatmap(
            confusion_matrix(y_test, y_pred), annot=True, fmt="d", cmap="Blues",
            xticklabels=class_names, yticklabels=class_names, ax=ax,
        )
        ax.set_title(f"Confusion Matrix — {name}", fontweight="bold")
        ax.set_xlabel("Predicted")
        ax.set_ylabel("Actual")
        plt.tight_layout()
        plt.savefig(fig_dir / "confusion_matrix.png", dpi=150, bbox_inches="tight")
        plt.close(fig)

        fpr_arr, tpr_arr, _ = roc_curve(y_test, y_prob)
        fig, ax = plt.subplots(figsize=(6, 5))
        ax.plot(fpr_arr, tpr_arr, lw=2, label=f"AUC = {metrics['auc']:.4f}")
        ax.plot([0, 1], [0, 1], "--", color="grey", linewidth=1)
        ax.set_xlabel("False Positive Rate")
        ax.set_ylabel("True Positive Rate")
        ax.set_title(f"ROC Curve — {name}", fontweight="bold")
        ax.legend(loc="lower right")
        plt.tight_layout()
        plt.savefig(fig_dir / "roc_curve.png", dpi=150, bbox_inches="tight")
        plt.close(fig)

        # ── Standardized result output (feeds make_comparisons.py) ───
        result_dir = results_root / slug
        result = (
            ExperimentResult(name, "centralized")
            .set_params(
                test_size=test_size,
                random_state=random_state,
                features=feature_names,
                num_features=len(feature_names),
            )
            .set_metrics(**metrics)
            .set_confusion_matrix(tn, fp, fn, tp)
        )
        ResultWriter.save_metrics_json(result, result_dir / "metrics_summary.json")

    # ── Combined confusion-matrix grid across all 4 models ───────────
    comparisons_dir = figures_root / "comparisons"
    comparisons_dir.mkdir(parents=True, exist_ok=True)

    fig, axes = plt.subplots(2, 2, figsize=(12, 10))
    axes = axes.flatten()
    for i, name in enumerate(models):
        cm = confusion_matrix(y_test, all_predictions[name]["y_pred"])
        sns.heatmap(cm, annot=True, fmt="d", cmap="Blues",
                    xticklabels=class_names, yticklabels=class_names, ax=axes[i])
        axes[i].set_title(f"Confusion Matrix — {name}", fontweight="bold", fontsize=12)
        axes[i].set_xlabel("Predicted")
        axes[i].set_ylabel("Actual")
    plt.suptitle("Confusion Matrices — Centralized Classifiers", fontsize=14, fontweight="bold", y=1.01)
    plt.tight_layout()
    plt.savefig(comparisons_dir / "cm_all_centralized.png", dpi=150, bbox_inches="tight")
    plt.close(fig)

    colors = ["#3498db", "#2ecc71", "#e67e22", "#9b59b6"]
    fig, ax = plt.subplots(figsize=(8, 6))
    for (name, metrics), color in zip(all_results.items(), colors):
        fpr_arr, tpr_arr, _ = roc_curve(y_test, all_predictions[name]["y_prob"])
        ax.plot(fpr_arr, tpr_arr, lw=2, color=color, label=f"{name} (AUC={metrics['auc']:.4f})")
    ax.plot([0, 1], [0, 1], "--", color="grey", linewidth=1)
    ax.set_xlabel("False Positive Rate")
    ax.set_ylabel("True Positive Rate")
    ax.set_title("ROC Curves — Centralized Classifiers", fontweight="bold")
    ax.legend(loc="lower right")
    plt.tight_layout()
    plt.savefig(comparisons_dir / "roc_centralized.png", dpi=150, bbox_inches="tight")
    plt.close(fig)

    print("\nAll centralized models trained and results saved.")
    print(f"Figures : {figures_root}")
    print(f"Results : {results_root}")
    return all_results


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Train centralized baseline models")
    parser.add_argument("--config", default="configs/experiment_baselines.yaml")
    parser.add_argument("--dataset", default=None, help="Override dataset CSV path")
    parser.add_argument("--all-features", action="store_true",
                         help="Use all numeric columns (matches FL script) instead of the fixed 8-feature subset")
    args = parser.parse_args()

    cfg = load_config(args.config)
    dataset_path = args.dataset or cfg.get("dataset", {}).get("path")
    if not dataset_path:
        print("❌ No dataset path given. Use --dataset or set it in the config YAML.")
        sys.exit(1)

    run_centralized_models(
        dataset_path=dataset_path,
        target_col=cfg.get("dataset", {}).get("target_col", "Label"),
        test_size=cfg.get("dataset", {}).get("test_split", 0.2),
        random_state=cfg.get("random_state", 42),
        reports_dir=cfg.get("output", {}).get("reports_dir", "reports"),
        use_all_features=args.all_features,
    )
